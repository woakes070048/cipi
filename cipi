set -euo pipefail

readonly CIPI_LIB="/opt/cipi/lib"
readonly CIPI_CONFIG="/etc/cipi"
readonly CIPI_VERSION="$(tr -d '[:space:]' < "${CIPI_CONFIG}/version" 2>/dev/null || echo "unknown")"
readonly CIPI_LOG="/var/log/cipi"

RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[1;33m'
CYAN=$'\033[0;36m'; DIM=$'\033[2m'; NC=$'\033[0m'; BOLD=$'\033[1m'

[[ -f "${CIPI_LIB}/common.sh" ]] || {
    echo "Cipi: missing ${CIPI_LIB}/common.sh — run the installer: curl -sSL https://cipi.sh/setup.sh | sudo bash" >&2
    exit 1
}
source "${CIPI_LIB}/common.sh"

require_root() {
    if [[ $EUID -ne 0 ]]; then
        error "Run as root: sudo cipi $*"
        exit 1
    fi
}

show_logo() {
    echo -e "${GREEN}${BOLD}"
    echo " ██████ ██ ██████  ██"
    echo "██      ██ ██   ██ ██"
    echo "██      ██ ██████  ██"
    echo "██      ██ ██      ██"
    echo " ██████ ██ ██      ██"
    echo -e "${NC}"
}

show_help() {
    show_logo
    echo -e "${BOLD}Cipi v${CIPI_VERSION}${NC} ${DIM}— Server Control Panel for Laravel${NC}"
    echo ""
    echo -e "  ${BOLD}${CYAN}SERVER${NC}"
    echo -e "    ${CYAN}cipi status${NC}                         Server status"
    echo -e "    ${CYAN}cipi version${NC}                        Cipi version"
    echo -e "    ${CYAN}cipi self-update [--check]${NC}          Update Cipi"
    echo ""
    echo -e "  ${BOLD}${CYAN}SERVICES${NC}"
    echo -e "    ${CYAN}cipi service list [service]${NC}         Services status"
    echo -e "    ${CYAN}cipi service restart [service|all]${NC}  Restart service(s)"
    echo -e "    ${CYAN}cipi service start <service>${NC}        Start a service"
    echo -e "    ${CYAN}cipi service stop <service>${NC}         Stop a service"
    echo -e "    ${DIM}  services: nginx mariadb supervisor fail2ban php<ver>-fpm${NC}"
    echo ""
    echo -e "  ${BOLD}${CYAN}APPS${NC}"
    echo -e "    ${CYAN}cipi app create${NC}                     Create Laravel app (interactive)"
    echo -e "    ${CYAN}cipi app list${NC}                       List apps"
    echo -e "    ${CYAN}cipi app show <app>${NC}                 App details"
    echo -e "    ${CYAN}cipi app edit <app> [--php=X.Y]${NC}     Edit app"
    echo -e "    ${CYAN}cipi app delete <app>${NC}               Delete app"
    echo -e "    ${CYAN}cipi app env <app>${NC}                  Edit .env"
    echo -e "    ${CYAN}cipi app logs <app> [--type=T]${NC}      Tail logs"
    echo -e "    ${CYAN}cipi app tinker <app>${NC}               Laravel Tinker"
    echo -e "    ${CYAN}cipi app artisan <app> <cmd>${NC}        Artisan command"
    echo ""
    echo -e "  ${BOLD}${CYAN}DOMAINS${NC}"
    echo -e "    ${CYAN}cipi alias add <app> <domain>${NC}       Add alias"
    echo -e "    ${CYAN}cipi alias remove <app> <domain>${NC}    Remove alias"
    echo -e "    ${CYAN}cipi alias list <app>${NC}               List aliases"
    echo ""
    echo -e "  ${BOLD}${CYAN}AUTH${NC}"
    echo -e "    ${CYAN}cipi auth create <app>${NC}              Create auth.json in shared"
    echo -e "    ${CYAN}cipi auth edit <app>${NC}                Edit auth.json"
    echo -e "    ${CYAN}cipi auth show <app>${NC}                Show auth.json content"
    echo -e "    ${CYAN}cipi auth delete <app>${NC}              Delete auth.json"
    echo ""
    echo -e "  ${BOLD}${CYAN}DEPLOY${NC}"
    echo -e "    ${CYAN}cipi deploy <app>${NC}                        Deploy via Deployer"
    echo -e "    ${CYAN}cipi deploy <app> --rollback${NC}             Rollback"
    echo -e "    ${CYAN}cipi deploy <app> --releases${NC}             List releases"
    echo -e "    ${CYAN}cipi deploy <app> --key${NC}                  Show SSH deploy key"
    echo -e "    ${CYAN}cipi deploy <app> --webhook${NC}              Show webhook info"
    echo -e "    ${CYAN}cipi deploy <app> --unlock${NC}               Unlock a stuck deploy"
    echo -e "    ${CYAN}cipi deploy <app> --trust-host=<host[:port]>${NC}  Trust a custom Git server"
    echo ""
    echo -e "  ${BOLD}${CYAN}WORKERS${NC}"
    echo -e "    ${CYAN}cipi worker add <app> [--queue=Q]${NC}    Add worker"
    echo -e "    ${CYAN}cipi worker list <app>${NC}              List workers"
    echo -e "    ${CYAN}cipi worker remove <app> <queue>${NC}    Remove worker"
    echo -e "    ${CYAN}cipi worker restart <app>${NC}           Restart workers"
    echo ""
    echo -e "  ${BOLD}${CYAN}DATABASE${NC}"
    echo -e "    ${CYAN}cipi db create${NC}                      Create database"
    echo -e "    ${CYAN}cipi db list${NC}                        List databases"
    echo -e "    ${CYAN}cipi db delete <name>${NC}                Delete database"
    echo -e "    ${CYAN}cipi db backup <name>${NC}               Backup database"
    echo -e "    ${CYAN}cipi db restore <name> <file>${NC}        Restore database"
    echo ""
    echo -e "  ${BOLD}${CYAN}API${NC}"
    echo -e "    ${CYAN}cipi api <domain>${NC}                 Configure API at domain"
    echo -e "    ${CYAN}cipi api ssl${NC}                      SSL for API domain"
    echo -e "    ${CYAN}cipi api update${NC}                   Update Laravel + cipi-api (composer update)"
    echo -e "    ${CYAN}cipi api upgrade${NC}                  Full rebuild (fresh Laravel + package)"
    echo -e "    ${CYAN}cipi api status${NC}                   Show API versions and status"
    echo -e "    ${CYAN}cipi api token list|create|revoke${NC} API token management"
    echo ""
    echo -e "  ${BOLD}${CYAN}GIT INTEGRATION${NC}"
    echo -e "    ${CYAN}cipi git status${NC}                      Git provider status"
    echo -e "    ${CYAN}cipi git github-token <token>${NC}        Save GitHub PAT"
    echo -e "    ${CYAN}cipi git gitlab-token <token>${NC}        Save GitLab PAT"
    echo -e "    ${CYAN}cipi git gitlab-url <url>${NC}            Self-hosted GitLab URL"
    echo -e "    ${CYAN}cipi git remove-github${NC}               Remove GitHub token"
    echo -e "    ${CYAN}cipi git remove-gitlab${NC}               Remove GitLab token + URL"
    echo ""
    echo -e "  ${BOLD}${CYAN}SYNC${NC}"
    echo -e "    ${CYAN}cipi sync export [app ...] [opts]${NC}  Export apps to archive"
    echo -e "    ${CYAN}cipi sync import <file> [app ...]${NC}  Import apps from archive"
    echo -e "    ${CYAN}cipi sync push [app ...] [opts]${NC}    Export + transfer to remote server"
    echo -e "    ${CYAN}cipi sync list <file>${NC}              Inspect archive contents"
