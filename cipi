# License: MIT
#############################################

set -euo pipefail

readonly CIPI_VERSION="4.0.0"
readonly CIPI_LIB="/opt/cipi/lib"
readonly CIPI_CONFIG="/etc/cipi"
readonly CIPI_LOG="/var/log/cipi"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; NC='\033[0m'; BOLD='\033[1m'

[[ -f "${CIPI_LIB}/common.sh" ]] || {
    echo "Cipi: missing ${CIPI_LIB}/common.sh — run the installer: curl -sSL https://raw.githubusercontent.com/andreapollastri/cipi/main/install.sh | sudo bash" >&2
    exit 1
}
source "${CIPI_LIB}/common.sh"

require_root() {
    if [[ $EUID -ne 0 ]]; then
        error "Run as root: sudo cipi $*"
        exit 1
    fi
}

show_logo() {
    echo -e "${GREEN}${BOLD}"
    echo " ██████ ██ ██████  ██"
    echo "██      ██ ██   ██ ██"
    echo "██      ██ ██████  ██"
    echo "██      ██ ██      ██"
    echo " ██████ ██ ██      ██"
    echo -e "${NC}"
}

show_help() {
    show_logo
    cat <<EOF
${BOLD}Cipi v${CIPI_VERSION}${NC} — Server Control Panel for Laravel

${BOLD}SERVER${NC}
  cipi status                         Server status
  cipi version                        Cipi version
  cipi self-update [--check]          Update Cipi

${BOLD}APPS${NC}
  cipi app create                     Create Laravel app (interactive)
  cipi app list                       List apps
  cipi app show <app>                 App details
  cipi app edit <app> [--php=X.Y]     Edit app
  cipi app delete <app>               Delete app
  cipi app env <app>                  Edit .env
  cipi app logs <app> [--type=T]      Tail logs
  cipi app tinker <app>               Laravel Tinker
  cipi app artisan <app> <cmd>        Artisan command

${BOLD}DOMAINS${NC}
  cipi alias add <app> <domain>       Add alias
  cipi alias remove <app> <domain>    Remove alias
  cipi alias list <app>               List aliases

${BOLD}DEPLOY${NC}
  cipi deploy <app>                   Deploy via Deployer
  cipi deploy <app> --rollback        Rollback
  cipi deploy <app> --releases        List releases
  cipi deploy <app> --key             Show SSH deploy key
  cipi deploy <app> --webhook         Show webhook info

${BOLD}WORKERS${NC}
  cipi worker add <app> [--queue=Q]   Add worker
  cipi worker list <app>              List workers
  cipi worker remove <app> <queue>    Remove worker
  cipi worker restart <app>           Restart workers

${BOLD}DATABASE${NC}
  cipi db create                      Create database
  cipi db list                        List databases
  cipi db delete <name>               Delete database
  cipi db backup <name>               Backup database
  cipi db restore <name> <file>       Restore database

${BOLD}SSL / PHP / FIREWALL / BACKUP${NC}
  cipi ssl install <app>              SSL certificate
  cipi ssl renew                      Renew all certs
  cipi php list                       PHP versions
  cipi php install <ver>              Install PHP
  cipi firewall allow <port>          Allow port
  cipi firewall list                  Firewall rules
  cipi backup configure               Configure S3
  cipi backup run [app]               Run backup
EOF
}

show_status() {
    show_logo
    echo -e "${BOLD}Server Status${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

    local ip; ip=$(curl -s --max-time 5 https://checkip.amazonaws.com 2>/dev/null || echo "N/A")
    echo -e "\n${BOLD}System${NC}"
    printf "  %-14s ${CYAN}%s${NC}\n" "IP" "$ip"
    printf "  %-14s ${CYAN}%s${NC}\n" "Hostname" "$(hostname)"
    printf "  %-14s ${CYAN}%s${NC}\n" "OS" "$(lsb_release -ds 2>/dev/null)"
    printf "  %-14s ${CYAN}%s${NC}\n" "Uptime" "$(uptime -p 2>/dev/null)"
    printf "  %-14s ${CYAN}v%s${NC}\n" "Cipi" "$CIPI_VERSION"

    local cpu; cpu=$(top -bn1 | grep "Cpu(s)" | awk '{print $2}' | cut -d. -f1 2>/dev/null || echo "?")
    local mem_total; mem_total=$(free -m | awk '/^Mem:/{print $2}')
    local mem_used; mem_used=$(free -m | awk '/^Mem:/{print $3}')
    echo -e "\n${BOLD}Resources${NC}"
    printf "  %-14s ${CYAN}%s%%${NC}\n" "CPU" "$cpu"
    printf "  %-14s ${CYAN}%sMB / %sMB (%s%%)${NC}\n" "Memory" "$mem_used" "$mem_total" "$((mem_used*100/mem_total))"
    printf "  %-14s ${CYAN}%s${NC}\n" "Disk" "$(df -h / | awk 'NR==2{print $3"/"$2" ("$5")"}')"

    echo -e "\n${BOLD}Services${NC}"
    for svc in nginx mariadb redis-server supervisor fail2ban; do
        if systemctl is-active --quiet "$svc" 2>/dev/null; then
            printf "  %-16s ${GREEN}● running${NC}\n" "$svc"
        else
            printf "  %-16s ${RED}● stopped${NC}\n" "$svc"
        fi
    done

    echo -e "\n${BOLD}PHP${NC}"
    for v in 8.1 8.2 8.3 8.4; do
        if systemctl is-active --quiet "php${v}-fpm" 2>/dev/null; then
            local pools; pools=$(ls /etc/php/${v}/fpm/pool.d/*.conf 2>/dev/null | wc -l)
            printf "  %-16s ${GREEN}● running${NC} (%d pools)\n" "PHP $v" "$pools"
        fi
    done

    local count=0
    [[ -f "${CIPI_CONFIG}/apps.json" ]] && count=$(jq 'length' "${CIPI_CONFIG}/apps.json" 2>/dev/null || echo 0)
    echo -e "\n${BOLD}Apps:${NC} ${CYAN}${count}${NC}\n"
}

main() {
    [[ $# -eq 0 ]] && { show_help; exit 0; }

    local cmd="$1"; shift || true

    case "$cmd" in
        help|--help|-h)       show_help ;;
        version|--version|-v) echo "Cipi v${CIPI_VERSION}" ;;
        status)     require_root; show_status ;;
        app)        require_root; source "${CIPI_LIB}/app.sh";         app_command "$@" ;;
        alias)      require_root; source "${CIPI_LIB}/app.sh";         alias_command "$@" ;;
        deploy)     require_root; source "${CIPI_LIB}/deploy.sh";      deploy_command "$@" ;;
        worker)     require_root; source "${CIPI_LIB}/worker.sh";      worker_command "$@" ;;
        db)         require_root; source "${CIPI_LIB}/db.sh";          db_command "$@" ;;
        ssl)        require_root; source "${CIPI_LIB}/ssl.sh";         ssl_command "$@" ;;
        php)        require_root; source "${CIPI_LIB}/php.sh";         php_command "$@" ;;
        firewall)   require_root; source "${CIPI_LIB}/firewall.sh";    firewall_command "$@" ;;
        backup)     require_root; source "${CIPI_LIB}/backup.sh";      backup_command "$@" ;;
        self-update) require_root; source "${CIPI_LIB}/self-update.sh"; selfupdate_command "$@" ;;
        *) error "Unknown command: $cmd"; echo "Run 'cipi help'"; exit 1 ;;
    esac
}

main "$@"
